name: Build ImmortalWrt

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3
        with:
          repository: immortalwrt/immortalwrt
          ref: master

      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y build-essential libncurses5-dev gawk zlib1g-dev git python3 unzip wget curl

      - name: Add 5G plugin
        run: |
          rm -rf package/5g-modem-support
          git clone https://github.com/wshcxl/5G-Modem-Support.git package/5g-modem-support

      - name: Feeds
        run: |
          ./scripts/feeds update -a
          ./scripts/feeds install -a

      - name: Config
        run: |
          cp configs/phicomm_psg1218a.config .config
          make defconfig

      - name: Compile
        run: make -j1 V=s
